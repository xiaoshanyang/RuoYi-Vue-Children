<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.ActivityTemplateMapper">

    <resultMap type="com.ruoyi.system.domain.ActivityTemplate" id="ActivityTemplateResult">
        <result property="templateId" column="template_id" />
        <result property="tempName" column="temp_name" />
        <result property="tempContent" column="temp_content" />
        <result property="safeNotice" column="safe_notice" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <select id="selectActivityTemplateList" parameterType="ActivityTemplate" resultMap="ActivityTemplateResult">
        select template_id, temp_name, temp_content, safe_notice, create_by, create_time, remark
        from activity_template
        <where>
            <if test="tempName != null and tempName != ''">
                and temp_name like concat('%', #{tempName}, '%')
            </if>
            <if test="safeNotice != null and safeNotice != ''">
                and safe_notice like concat('%', #{safeNotice}, '%')
            </if>
        </where>
        order by template_id desc
    </select>

    <select id="selectActivityTemplateById" parameterType="Long" resultMap="ActivityTemplateResult">
        select * from activity_template where template_id = #{templateId}
    </select>

    <insert id="insertActivityTemplate" parameterType="ActivityTemplate">
        insert into activity_template(temp_name, temp_content, safe_notice, create_by, create_time, remark)
        values(#{tempName}, #{tempContent}, #{safeNotice}, #{createBy}, now(), #{remark})
    </insert>

    <update id="updateActivityTemplate" parameterType="ActivityTemplate">
        update activity_template
        <set>
            <if test="tempName != null">temp_name = #{tempName},</if>
            <if test="tempContent != null">temp_content = #{tempContent},</if>
            <if test="safeNotice != null">safe_notice = #{safeNotice},</if>
            <if test="remark != null">remark = #{remark}</if>
        </set>
        where template_id = #{templateId}
    </update>

    <delete id="deleteActivityTemplateById" parameterType="Long">
        delete from activity_template where template_id = #{templateId}
    </delete>

</mapper>

