<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.WarehouseOutItemMapper">

    <resultMap type="com.ruoyi.system.domain.WarehouseOutItem" id="WarehouseOutItemResult">
        <result property="id" column="id"/>
        <result property="outId" column="out_id"/>
        <result property="foodId" column="food_id"/>
        <result property="foodName" column="food_name"/>
        <result property="outQty" column="out_qty"/>
        <result property="batchId" column="batch_id"/>
    </resultMap>

    <select id="selectByOutId" resultMap="WarehouseOutItemResult">
      SELECT
          id,
          out_id,
          food_id,
          food_name,
          out_qty,
          batch_id
      FROM warehouse_out_item
      WHERE out_id = #{outId}
      ORDER BY id ASC
  </select>

  <insert id="insert" parameterType="com.ruoyi.system.domain.WarehouseOutItem" useGeneratedKeys="true" keyProperty="id">
        insert into warehouse_out_item
         <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="outId != null">out_id,</if>
            <if test="foodId != null">food_id,</if>
            <if test="foodName != null">food_name,</if>
            <if test="outQty != null">out_qty,</if>
            <if test="batchId != null">batch_id,</if>
         </trim>
         <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="outId != null">#{outId},</if>
            <if test="foodId != null">#{foodId},</if>
            <if test="foodName != null">#{foodName},</if>
            <if test="outQty != null">#{outQty},</if>
            <if test="batchId != null">#{batchId},</if>
         </trim>
    </insert>
</mapper>