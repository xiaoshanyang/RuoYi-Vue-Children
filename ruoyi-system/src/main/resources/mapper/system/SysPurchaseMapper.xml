<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysPurchaseMapper">
    
     <resultMap type="com.ruoyi.system.domain.SysPurchase" id="PurchaseResult">
        <result property="purchaseId" column="purchase_id"/>
        <result property="purchaseNo" column="purchase_no"/>
        <result property="supplierId" column="supplier_id"/>
        <result property="supplierName" column="supplier_name"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="actualAmount" column="actual_amount"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="auditBy" column="audit_by"/>
        <result property="auditTime" column="audit_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <resultMap id="PurchaseItemResult" type="com.ruoyi.system.domain.SysPurchaseItem">
        <result property="itemId" column="item_id"/>
        <result property="purchaseId" column="purchase_id"/>
        <result property="foodId" column="food_id"/>
        <result property="foodName" column="food_name"/>
        <result property="foodType" column="food_type"/>
        <result property="unit" column="unit"/>
        <result property="price" column="price"/>
        <result property="qty" column="qty"/>
        <result property="subTotal" column="sub_total"/>
    </resultMap>

    <select id="selectPurchaseList" parameterType="com.ruoyi.system.domain.SysPurchase" resultMap="PurchaseResult">
        select * from sys_purchase
        <where>
            <if test="purchaseNo != null">and purchase_no like concat('%',#{purchaseNo},'%')</if>
            <if test="supplierName != null">and supplier_name like concat('%',#{supplierName},'%')</if>
            <if test="status != null">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPurchaseById" parameterType="Long" resultMap="PurchaseResult">
        select * from sys_purchase where purchase_id = #{purchaseId}
    </select>

    <insert id="insertPurchase" parameterType="com.ruoyi.system.domain.SysPurchase" useGeneratedKeys="true" keyProperty="purchaseId" keyColumn="purchase_id">
        insert into sys_purchase
        (purchase_no, supplier_id, supplier_name, total_amount, status, remark,
         create_by, create_time, update_by, update_time)
        values
        (#{purchaseNo}, #{supplierId}, #{supplierName}, #{totalAmount}, #{status}, #{remark},
         #{createBy}, #{createTime}, #{updateBy}, #{updateTime})
    </insert>

    <update id="updatePurchase" parameterType="com.ruoyi.system.domain.SysPurchase">
        update sys_purchase
        <set>
            <if test="purchaseNo != null">purchase_no = #{purchaseNo},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="supplierName != null">supplier_name = #{supplierName},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="auditBy != null">audit_by = #{auditBy},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime}</if>
        </set>
        where purchase_id = #{purchaseId}
    </update>

    <delete id="deletePurchaseByIds" parameterType="Long">
        delete from sys_purchase where purchase_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 明细 -->
    <insert id="insertPurchaseItems">
        insert into sys_purchase_item
        (purchase_id, food_id, price, qty, sub_total)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.purchaseId}, #{item.foodId}, #{item.price}, #{item.qty}, #{item.subTotal})
        </foreach>
    </insert>

    <select id="selectItemsByPurchaseId" parameterType="Long" resultMap="PurchaseItemResult">
        select spi.purchase_id, spi.food_id, spi.price, spi.qty, spi.sub_total,
               sfi.food_name ,sfi.unit,sfi.food_type
        from sys_purchase_item spi
        left join sys_food_info sfi on spi.food_id = sfi.food_id
        where spi.purchase_id = #{purchaseId}
    </select>

    <delete id="deleteItemsByPurchaseId" parameterType="Long">
        delete from sys_purchase_item where purchase_id = #{purchaseId}
    </delete>
</mapper>