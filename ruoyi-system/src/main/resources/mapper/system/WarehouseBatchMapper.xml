<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xxx.mapper.WarehouseBatchMapper">

    <select id="selectAvailableBatch" resultType="WarehouseBatch">
        select * from warehouse_batch
        where food_id = #{foodId} and remain_qty > 0
        order by in_time asc
    </select>

    <update id="updateById">
        update warehouse_batch
        set remain_qty = #{remainQty}
        where batch_id = #{batchId}
    </update>

    <insert id="insert" useGeneratedKeys="true" keyProperty="batchId">
        insert into warehouse_batch(food_id,food_name,purchase_id,check_id,in_qty,remain_qty,in_time,create_by)
        values (#{foodId},#{foodName},#{purchaseId},#{checkId},#{inQty},#{remainQty},#{inTime},#{createBy})
    </insert>

    
</mapper>