<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysActivityMapper">
    
    <resultMap type="SysActivity" id="SysActivityResult">
        <result property="id"    column="id"    />
        <result property="activityName"    column="activity_name"    />
        <result property="activityType"    column="activity_type"    />
        <result property="className"    column="class_name"    />
        <result property="activityPlace"    column="activity_place"    />
        <result property="presetDuration"    column="preset_duration"    />
        <result property="actualDuration"    column="actual_duration"    />
        <result property="activityStatus"    column="activity_status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectSysActivityVo">
        select id, activity_name, activity_type, class_name, activity_place, preset_duration, actual_duration, activity_status, create_by, create_time, update_by, update_time from sys_activity
    </sql>

    <select id="selectSysActivityList" parameterType="SysActivity" resultMap="SysActivityResult">
        <include refid="selectSysActivityVo"/>
        <where>  
            <if test="activityName != null  and activityName != ''"> and activity_name like concat('%', #{activityName}, '%')</if>
            <if test="activityType != null  and activityType != ''"> and activity_type = #{activityType}</if>
            <if test="className != null  and className != ''"> and class_name like concat('%', #{className}, '%')</if>
            <if test="activityPlace != null  and activityPlace != ''"> and activity_place = #{activityPlace}</if>
            <if test="presetDuration != null and presetDuration > 0"> and preset_duration = #{presetDuration}</if>
            <if test="actualDuration != null and actualDuration > 0"> and actual_duration = #{actualDuration}</if>
            <if test="activityStatus != null  and activityStatus != ''"> and activity_status = #{activityStatus}</if>
        </where>
    </select>
    
    <select id="selectSysActivityById" parameterType="Long" resultMap="SysActivityResult">
        <include refid="selectSysActivityVo"/>
        where id = #{id}
    </select>

    <insert id="insertSysActivity" parameterType="SysActivity" useGeneratedKeys="true" keyProperty="id">
        insert into sys_activity
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="activityName != null and activityName != ''">activity_name,</if>
            <if test="activityType != null and activityType != ''">activity_type,</if>
            <if test="className != null and className != ''">class_name,</if>
            <if test="activityPlace != null">activity_place,</if>
            <if test="presetDuration != null">preset_duration,</if>
            <if test="actualDuration != null">actual_duration,</if>
            <if test="activityStatus != null">activity_status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="activityName != null and activityName != ''">#{activityName},</if>
            <if test="activityType != null and activityType != ''">#{activityType},</if>
            <if test="className != null and className != ''">#{className},</if>
            <if test="activityPlace != null">#{activityPlace},</if>
            <if test="presetDuration != null">#{presetDuration},</if>
            <if test="actualDuration != null">#{actualDuration},</if>
            <if test="activityStatus != null">#{activityStatus},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateSysActivity" parameterType="SysActivity">
        update sys_activity
        <trim prefix="SET" suffixOverrides=",">
            <if test="activityName != null and activityName != ''">activity_name = #{activityName},</if>
            <if test="activityType != null and activityType != ''">activity_type = #{activityType},</if>
            <if test="className != null and className != ''">class_name = #{className},</if>
            <if test="activityPlace != null">activity_place = #{activityPlace},</if>
            <if test="presetDuration != null">preset_duration = #{presetDuration},</if>
            <if test="actualDuration != null">actual_duration = #{actualDuration},</if>
            <if test="activityStatus != null">activity_status = #{activityStatus},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSysActivityById" parameterType="Long">
        delete from sys_activity where id = #{id}
    </delete>

    <delete id="deleteSysActivityByIds" parameterType="String">
        delete from sys_activity where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>